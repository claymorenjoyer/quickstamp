# Copy this to .env and fill in secure values:
#   cp .env.sample .env

# Database credentials
DB_USER=quickstamp
DB_PASSWORD=use_a_secure_random_password
DB_NAME=quickstamp
DB_PORT=5432

# Connection string used by the app. Docker Compose builds its own from the
# DB_* values above — this one is for local development (`npm run dev`).
# Keep it in sync with DB_USER / DB_PASSWORD / DB_NAME / DB_PORT.
DATABASE_URL=postgresql://quickstamp:use_a_secure_random_password@localhost:5432/quickstamp

# Auth secret — generate with: openssl rand -base64 64
AUTH_SECRET=use_a_secure_random_secret

# Public URL of your server (use https:// in production)
AUTH_URL=http://localhost:3000

# App port
APP_PORT=3000

# pgAdmin (optional, run with: docker compose --profile tools up -d)
PGADMIN_EMAIL=admin@quickstamp.local
PGADMIN_PASSWORD=use_a_secure_password
PGADMIN_PORT=5050
