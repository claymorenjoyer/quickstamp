# Copy this to .env and fill in secure values:
#   cp .env.sample .env

# Database credentials
DB_USER=quickstamp
DB_PASSWORD=use_a_secure_random_password
DB_NAME=quickstamp
DB_PORT=5432

# Auth secret — generate with: openssl rand -base64 64
AUTH_SECRET=use_a_secure_random_secret

# Public URL of your server (use https:// in production)
AUTH_URL=http://localhost:3000

# App port
APP_PORT=3000

# pgAdmin (optional, run with: docker compose --profile tools up -d)
PGADMIN_EMAIL=admin@quickstamp.local
PGADMIN_PASSWORD=use_a_secure_password
PGADMIN_PORT=5050
